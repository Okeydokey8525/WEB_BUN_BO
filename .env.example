# Production datasource (required when SPRING_PROFILES_ACTIVE=prod)
DB_URL=jdbc:postgresql://localhost:5432/bunbo
DB_USERNAME=
DB_PASSWORD=

# Filesystem and session configuration
APP_UPLOAD_DIR=/var/lib/bunbo/uploads
SESSION_TIMEOUT=30m

# Configure real bank details only in the deployment environment.
BANK_ID=
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_NAME=
